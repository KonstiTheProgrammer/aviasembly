; Engine configuration file.
; Aviassembly — 3D Plane Builder (Godot 4.6)

config_version=5

[application]

config/name="Aviassembly"
config/description="Baue dein eigenes Flugzeug und fliege es! Ein 3D Plane Builder."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1366
window/size/viewport_height=768
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/default_gravity=9.81

[rendering]

renderer/rendering_method="forward_plus"
anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.55, 0.72, 0.92, 1)
